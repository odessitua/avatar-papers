arxiv:
  max_results_per_topic: 200
  sort_by: "submitted"       # "submitted" or "updated"
  search_field: "abs"        # "ti" (title), "abs" (abstract), "all" (all fields)
  # Lower bound for submittedDate (YYYY-MM-DD). Update to "today" for freshest results.
  date_from: "2026-03-23"
  # date_to: "2026-12-31"    # optional; omit for open-ended range (newest submissions)
  categories:
    - "cs.CV"
    - "cs.MM"
    - "cs.GR"
    - "cs.AI"
    - "cs.LG"
    - "cs.SD"
    - "eess.IV"
    - "eess.AS"

keywords:
  talking_head:
    - "Talking Face"
    - "Talking Head"
    - "Talking Avatar"
    - "Talking Video"
    - "Visual Dubbing"
  lip_sync:
    - "Lip Sync"
    - "Wav2Lip"
    - "Lip Generation"
    - "Lip Synchronization"
    - "Lip Expert"
  portrait_animation:
    - "Portrait Animation"
    - "Animate Portrait"
  face_reenactment:
    - "Face Reenactment"
    - "Face Generation"
    - "Facial Animation"
    - "Head Synthesis"
  image_animation:
    - "Image Animator"
    - "Image Animation"
  face_reconstruction:
    - "3D Face Reconstruction"
    - "3D Head Reconstruction"
    - "3D Morphable Model"
    - "3DMM"
    - "FLAME face model"
    - "Neural Parametric Head"
    - "Head Avatar Reconstruction"
    - "Gaussian Head Avatar"
    - "Face Geometry"

paths:
  csv_file: "data/papers.csv"
  db_file: "data/papers.db"
  publish_state: "data/publish_state.json"
  originals_dir: "papers/originals"
  analysis_dir: "papers/analysis"
  analysis_ru_dir: "papers/analysis_ru"
  figures_dir: "papers/figures"

code_search:
  enabled: true
  delay: 6.5   # seconds between GitHub Search API requests (rate limit)

download:
  delay: 3.0
  timeout: 120

confluence:
  space_key: "YOUR_SPACE_KEY"
  parent_page_id: "YOUR_PARENT_PAGE_ID"
  papers_page_title: "Papers"
  ru_page_title: "RU"
  prompt_page_title: "Analysis Prompt"
  keywords_page_title: "Search Keywords"
